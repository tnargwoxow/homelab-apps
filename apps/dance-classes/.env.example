# Absolute path on the Proxmox host to your dance class video library.
# This directory is mounted read-only into the container at /videos.
VIDEOS_HOST_PATH=/path/on/proxmox/to/dance-videos

# LAN address you'll use to reach the app from your phone/laptop. The
# Caddy reverse proxy issues a self-signed cert covering this exact host
# so you can open https://<LAN_HOST>:8443 — required if you want the
# self-review camera mirror to work, since browsers gate getUserMedia
# to secure contexts. Plain HTTP on :8080 keeps working for Chromecast
# streaming (Chromecasts can't trust self-signed certs).
LAN_HOST=192.168.1.50
